.page-header{position:relative;text-align:center;overflow:hidden;height:120px;display:flex;align-items:center;justify-content:center}.page-header .page-banner{position:absolute;top:0;left:0;width:100%;height:100%;z-index:1}.page-header .page-banner svg{width:100%;height:100%;object-fit:cover}.page-header .header-content{position:relative;z-index:2}.page-header .header-content h1{margin:0;color:#fff;font-weight:700;text-shadow:0 2px 4px rgba(0,0,0,.3)}.page-header .inner{padding-top:0;padding-bottom:0}.publication .anchor-links a,.meeting .anchor-links a{color:#009b9e}.publication .anchor-links li::before,.meeting .anchor-links li::before{border-color:#009b9e}